---
import Base from '../layouts/Base.astro';

const problems = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`,
    title: 'Rate limits kill your flows',
    body: 'Direct API calls hit vendor rate limits at the worst moment — overnight syncs fail silently, data goes stale, and your team notices before you do.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`,
    title: 'Direct integrations break',
    body: 'Vendor API changes, webhook failures, and network timeouts turn point-to-point integrations into permanent on-call duty for your engineering team.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Scaling is an afterthought',
    body: 'What works for 10 users falls over at 1,000. Without the right queuing, retry logic, and infrastructure, growth breaks your automation instead of powering it.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Maintenance never ends',
    body: 'Every new platform version, deprecated endpoint, or changed schema means another ticket on your backlog — and someone has to own it forever.',
  },
];

const services = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4"/><path d="m16.24 7.76 2.83-2.83"/><path d="M18 12h4"/><path d="m16.24 16.24 2.83 2.83"/><path d="M12 18v4"/><path d="m4.93 19.07 2.83-2.83"/><path d="M2 12h4"/><path d="m4.93 4.93 2.83 2.83"/></svg>`,
    name: 'Workflow Automation',
    description:
      'We build and run the automation infrastructure — queuing, retries, error handling, and monitoring included. You get reliable flows that scale without ever thinking about the plumbing.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="2" y="2" rx="1.5"/><rect width="8" height="8" x="14" y="2" rx="1.5"/><rect width="8" height="8" x="2" y="14" rx="1.5"/><rect width="8" height="8" x="14" y="14" rx="1.5"/><path d="M10 6h4"/><path d="M6 10v4"/><path d="M18 10v4"/><path d="M10 18h4"/></svg>`,
    name: 'Platform Integration',
    description:
      'We sit between your platforms — handling rate limits, retries, and schema changes so your data stays in sync even when vendors make breaking changes. No fragile point-to-point wiring.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>`,
    name: 'Managed Infrastructure',
    description:
      'We own the infrastructure end-to-end — deployment, monitoring, scaling, and ongoing maintenance. When something breaks at 3am, that\'s our problem, not yours.',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    name: 'Consulting',
    description:
      'From architecture reviews to hands-on implementation — we help you design the right integration strategy for where you are today and where you\'re heading.',
  },
];

const platforms = [
  { name: 'ClickUp', color: '#7B68EE' },
  { name: 'Confluence', color: '#0052CC' },
  { name: 'AWS', color: '#FF9900' },
  { name: 'Notion', color: '#000000' },
];
---

<Base>
  <div class="relative min-h-screen overflow-hidden">
    <div class="grid-bg pointer-events-none absolute inset-0 -z-10"></div>

    <!-- Nav -->
    <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 sm:py-8">
      <a href="/" class="group flex items-center" aria-label="XAD Labs">
        <img src="/logoww.png" alt="XAD Labs" class="h-10 w-auto sm:h-12" width="220" height="48" />
      </a>
      <nav class="flex items-center gap-6 text-sm">
        <a href="#problem" class="text-ink-900/70 transition hover:text-ink-900">Why us</a>
        <a href="#services" class="text-ink-900/70 transition hover:text-ink-900">Services</a>
        <a href="#products" class="text-ink-900/70 transition hover:text-ink-900">Products</a>
        <a
          href="mailto:zameer@xadlabs.com"
          class="rounded-full bg-ink-900 px-4 py-2 text-ink-50 transition hover:bg-accent"
        >
          Contact
        </a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-6 pb-20 pt-16 sm:pt-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-ink-900/10 bg-white/60 px-3 py-1 text-xs font-medium text-ink-900/70 backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          Managed automation &amp; integration — we own the infrastructure
        </span>

        <h1 class="mt-6 font-serif text-5xl leading-[1.05] tracking-tightest text-ink-900 sm:text-7xl">
          Integrations that
          <span class="italic text-accent">scale</span>
          and stay up.
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-900/70">
          Direct integrations break under load, hit rate limits, and pile maintenance on your
          team. XAD Labs builds and runs the integration infrastructure for you — reliable,
          scalable, and fully maintained.
        </p>

        <!-- Platform badges -->
        <div class="mt-8 flex flex-wrap items-center gap-3">
          {platforms.map((p) => (
            <span class="inline-flex items-center gap-2 rounded-full border border-ink-900/10 bg-white/70 px-3 py-1.5 text-xs font-medium text-ink-900/80 backdrop-blur">
              <span class="h-2 w-2 rounded-full" style={`background:${p.color}`}></span>
              {p.name}
            </span>
          ))}
          <span class="text-xs text-ink-900/40">+ more</span>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a
            href="#problem"
            class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-5 py-3 text-sm font-medium text-ink-50 transition hover:bg-accent"
          >
            See how it works
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="mailto:zameer@xadlabs.com"
            class="inline-flex items-center gap-2 rounded-full border border-ink-900/15 bg-white/60 px-5 py-3 text-sm font-medium text-ink-900 backdrop-blur transition hover:border-ink-900/30"
          >
            Start a project
          </a>
        </div>
      </div>
    </section>

    <!-- Problem -->
    <section id="problem" class="mx-auto max-w-6xl px-6 pb-24">
      <div class="mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-900/50">
          The problem with direct integrations
        </p>
        <h2 class="mt-2 font-serif text-3xl tracking-tight text-ink-900 sm:text-4xl">
          Built it yourself? You'll maintain it forever.
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-900/60">
          Point-to-point integrations feel fast to ship — until they don't. Rate limits,
          vendor changes, and scale expose every assumption you made on day one.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {problems.map((p) => (
          <div class="flex gap-4 rounded-2xl border border-red-100 bg-red-50/60 p-6 backdrop-blur">
            <div class="mt-0.5 flex-shrink-0 text-red-400">
              <Fragment set:html={p.icon} />
            </div>
            <div>
              <h3 class="font-medium text-ink-900">{p.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-900/60">{p.body}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Bridge to solution -->
      <div class="mt-10 rounded-2xl border border-accent/20 bg-accent/5 px-8 py-6">
        <p class="text-sm leading-relaxed text-ink-900/70">
          <span class="font-semibold text-ink-900">XAD Labs handles all of this.</span>{' '}
          We design, build, and operate your integration infrastructure — including rate-limit
          management, automatic retries, scaling, and ongoing maintenance — so your team never
          has to think about it again.
        </p>
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="mx-auto max-w-6xl px-6 pb-24">
      <div class="mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-900/50">
          What we do
        </p>
        <h2 class="mt-2 font-serif text-3xl tracking-tight text-ink-900 sm:text-4xl">
          End-to-end — built, scaled, and maintained.
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <div class="flex flex-col gap-4 rounded-2xl border border-ink-900/10 bg-white/70 p-7 backdrop-blur">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-ink-900/10 bg-white text-accent">
              <Fragment set:html={s.icon} />
            </div>
            <h3 class="font-serif text-lg tracking-tight text-ink-900">{s.name}</h3>
            <p class="text-sm leading-relaxed text-ink-900/65">{s.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Platforms -->
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <div class="rounded-3xl border border-ink-900/10 bg-white/50 px-8 py-10 backdrop-blur sm:px-12">
        <p class="text-center text-xs font-medium uppercase tracking-[0.18em] text-ink-900/50">
          Platforms we integrate
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-6">
          {platforms.map((p) => (
            <div class="flex items-center gap-2.5 rounded-xl border border-ink-900/10 bg-white px-5 py-3 shadow-sm">
              <span class="h-3 w-3 rounded-full" style={`background:${p.color}`}></span>
              <span class="text-sm font-medium text-ink-900">{p.name}</span>
            </div>
          ))}
        </div>
        <p class="mt-8 text-center text-sm text-ink-900/50">
          Not on this list? We work across any platform with an API or webhook — and we handle the rate limits.
        </p>
      </div>
    </section>

    <!-- Products -->
    <section id="products" class="mx-auto max-w-6xl px-6 pb-24">
      <div class="mb-10">
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-900/50">
          Our product
        </p>
        <h2 class="mt-2 font-serif text-3xl tracking-tight text-ink-900 sm:text-4xl">
          Built for integration.
        </h2>
      </div>

      <a
        href="https://mdspec.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative flex flex-col overflow-hidden rounded-2xl border border-ink-900/10 bg-white/70 p-8 backdrop-blur transition hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_20px_60px_-20px_rgba(55,48,163,0.25)] sm:p-12 lg:flex-row lg:items-center lg:gap-12"
      >
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent opacity-0 transition group-hover:opacity-100"></div>

        <div class="flex-1">
          <div class="flex items-center gap-3">
            <h3 class="font-serif text-4xl tracking-tight text-ink-900">MDSpec</h3>
            <span class="rounded-full border border-accent/30 bg-accent/5 px-2.5 py-0.5 text-xs font-medium text-accent">Integration</span>
          </div>
          <p class="mt-1 font-mono text-xs text-ink-900/40">mdspec.dev</p>

          <p class="mt-4 text-base font-medium text-accent">
            Keep writing markdown. We'll handle the rest.
          </p>

          <p class="mt-3 max-w-lg text-[15px] leading-relaxed text-ink-900/70">
            Drop a mapping file in your repo, add one line to GitHub Actions, and every
            markdown file lands exactly where your team needs it — Confluence, Notion, or
            any documentation platform. No rate-limit headaches, no broken webhooks, no
            infrastructure to maintain. We run it all.
          </p>

          <ul class="mt-6 grid gap-2 sm:grid-cols-2 text-sm text-ink-900/70">
            {[
              'Repo-native, mapping-file driven',
              'One line of GitHub Actions',
              'Agent-powered transforms',
              'Confluence & Notion ready',
              'Rate limits managed for you',
              'Zero infrastructure to maintain',
            ].map((b) => (
              <li class="flex items-start gap-2">
                <span class="mt-[7px] h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="mt-8 flex-shrink-0 lg:mt-0">
          <div class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-6 py-3 text-sm font-medium text-ink-50 transition group-hover:bg-accent">
            Visit MDSpec
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
          </div>
        </div>
      </a>
    </section>

    <!-- Contact -->
    <section id="contact" class="mx-auto max-w-6xl px-6 pb-24">
      <div class="relative overflow-hidden rounded-3xl border border-ink-900/10 bg-ink-900 px-8 py-14 sm:px-14 sm:py-20">
        <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-accent/30 blur-3xl"></div>
        <div class="absolute -bottom-24 -left-10 h-72 w-72 rounded-full bg-accent/20 blur-3xl"></div>

        <div class="relative max-w-2xl">
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-50/50">
            Let's build together
          </p>
          <h2 class="mt-3 font-serif text-4xl tracking-tight text-ink-50 sm:text-5xl">
            Stop maintaining integrations. Start shipping.
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-ink-50/70">
            Tell us about your stack and where your integrations are causing pain. We'll
            take it from there — infrastructure, scaling, maintenance, and all.
          </p>

          <a
            href="mailto:zameer@xadlabs.com"
            class="mt-8 inline-flex items-center gap-3 rounded-full bg-ink-50 px-6 py-3.5 text-sm font-medium text-ink-900 transition hover:bg-accent hover:text-ink-50"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            zameer@xadlabs.com
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mx-auto max-w-6xl px-6 pb-10">
      <div class="flex flex-col items-start justify-between gap-4 border-t border-ink-900/10 pt-8 text-sm text-ink-900/50 sm:flex-row sm:items-center">
        <div class="flex items-center gap-3">
          <img src="/logoww.png" alt="XAD Labs" class="h-7 w-auto opacity-70" />
          <span>&copy; {new Date().getFullYear()} XAD Labs. Automation &amp; Integration.</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="#services" class="transition hover:text-ink-900">Services</a>
          <a href="https://mdspec.dev" target="_blank" rel="noopener noreferrer" class="transition hover:text-ink-900">MDSpec</a>
          <a href="mailto:zameer@xadlabs.com" class="transition hover:text-ink-900">Email</a>
        </div>
      </div>
    </footer>
  </div>
</Base>
