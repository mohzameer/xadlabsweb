---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base>
  <main class="mx-auto max-w-2xl px-6 py-20 sm:py-28">
    <!-- Intro -->
    <header>
      <h1 class="font-sans text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">XAD Labs</h1>
      <p class="mt-3 font-serif text-xl italic text-ink/60">
        Notes on distributed computing.
      </p>

      <div class="mt-8 max-w-xl text-[15px] leading-relaxed text-ink/70">
        <p>
          I'm <strong class="font-semibold text-ink">Mohammed Zameer</strong>, a Senior Technical
          Lead at <a
            href="https://99x.io"
            class="underline underline-offset-2 decoration-ink/30 hover:decoration-ink"
            >99x Asia</a
          >. I work on distributed computing and scaling problems — queues, caches, consensus, and
          everything that gets harder once one machine becomes many.
        </p>
        <p class="mt-3">
          This is where I write it down. No images, just text.
        </p>
      </div>
    </header>

    <!-- Posts -->
    <section class="mt-16">
      <div class="flex items-baseline justify-between">
        <h2 class="text-xs font-medium uppercase tracking-[0.2em] text-ink/40">Writing</h2>
        {
          import.meta.env.DEV && (
            <a
              href="/editor"
              class="font-mono text-xs text-ink/40 transition hover:text-ink"
            >
              + New post
            </a>
          )
        }
      </div>

      <ul class="mt-6 divide-y divide-ink/10 border-t border-ink/10">
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="group block py-6">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="font-sans text-xl font-bold tracking-tight text-ink transition group-hover:opacity-60">
                    {post.data.title}
                  </h3>
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="flex-shrink-0 font-mono text-xs text-ink/40"
                  >
                    {fmt(post.data.pubDate)}
                  </time>
                </div>
                {post.data.description && (
                  <p class="mt-2 max-w-xl text-[15px] leading-relaxed text-ink/60">
                    {post.data.description}
                  </p>
                )}
              </a>
            </li>
          ))
        }
      </ul>

      {
        posts.length === 0 && (
          <p class="mt-6 text-[15px] text-ink/50">No posts yet. Open the editor to write one.</p>
        )
      }
    </section>

    <!-- Footer -->
    <footer class="mt-24 border-t border-ink/10 pt-8 text-xs text-ink/40">
      <p>&copy; {new Date().getFullYear()} Mohammed Zameer · XAD Labs</p>
    </footer>
  </main>
</Base>
